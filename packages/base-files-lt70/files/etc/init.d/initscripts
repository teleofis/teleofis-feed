#!/bin/sh /etc/rc.common
# Copyright (C) 2017 teleofis

START=12
STOP=84

start()
{
	RESET_FLAG=$(fw_printenv -n factory_reset)
	if [[ "$RESET_FLAG" = "yes" ]]; then
		firstboot -y
		sync
		fw_setenv factory_reset
		reboot
	fi
	echo 25000000 > /sys/kernel/debug/mmc0/clock
	# modem init
	echo 527 > /sys/class/gpio/export
	echo high > /sys/class/gpio/gpio527/direction
	echo 512 > /sys/class/gpio/export
	echo high > /sys/class/gpio/gpio512/direction
	echo 525 > /sys/class/gpio/export
	echo in > /sys/class/gpio/gpio525/direction
	echo 526 > /sys/class/gpio/export
	echo in > /sys/class/gpio/gpio526/direction
	echo 528 > /sys/class/gpio/export
	echo low > /sys/class/gpio/gpio528/direction
	echo 529 > /sys/class/gpio/export
	echo low > /sys/class/gpio/gpio529/direction

	ln -s /dev/ttyS1 /dev/com0
	ln -s /dev/ttyS0 /dev/com1
	ln -s /dev/ttyS2 /dev/com2
}
